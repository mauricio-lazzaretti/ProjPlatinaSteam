@{
}
@model List<ProjPlatinaSteam.Models.Conquista>

    <h1>Conquistas</h1>


@if (Model != null && Model.Any())
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Nome conquista</th>
                <th>ApiNome</th>
                <th>Conquistada</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var conquista in Model)
            {
                <tr>
                    <td>@conquista.nome</td>
                    <td>@conquista.apiNome</td>
                    <td>@conquista.conquistada</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    
}
